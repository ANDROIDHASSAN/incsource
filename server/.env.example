# ─── Core ───────────────────────────────────────────────
PORT=4000
# Omit MONGODB_URI to use the built-in in-memory store (great for demos).
# MONGODB_URI=mongodb://localhost:27017/incruiter

# ─── Apify (enables real scraping providers) ────────────
# Get a token at https://console.apify.com/account/integrations
# APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxx

# ── Candidate discovery actors (defaults below; override to swap) ──
# LinkedIn — apimaestro: cheap, $0.005/result. Input: current_job_title, location.
APIFY_LINKEDIN_ACTOR=apimaestro/linkedin-profile-search-scraper
# LinkedIn — HarvestAPI: richest filters + openToWork flag (recommended).
APIFY_HARVEST_ACTOR=harvestapi/linkedin-profile-search
# Indeed resumes — real active job-seekers. $0.049/resume, needs residential proxy.
APIFY_INDEED_ACTOR=lexis-solutions/resume-indeed-com-scraper

# ── Enrichment: confirm #OpenToWork badge on LinkedIn profiles ──
APIFY_OTW_ACTOR=scrapers-hub/linkedin-open-to-work-status
# Set false to skip the confirmation pass:
# APIFY_OTW_ENRICH=false

# ── Hiring intel (Naukri JOB postings — NOT job-seekers) ──
APIFY_NAUKRI_ACTOR=memo23/naukri-scraper
# Find employer contact emails (billed per email found):
# APIFY_NAUKRI_EMAILS=true

# ── Cost / contact controls ──
# Resolve LinkedIn emails (slower, costs more):
# APIFY_INCLUDE_EMAIL=true
# Hard cap on results per source per run (controls spend):
# APIFY_MAX_ITEMS=100
# Per-result charge ceiling (USD) used to derive the run budget (~₹1/lead at 0.02):
# APIFY_USD_PER_ITEM=0.02
# Absolute ceiling for any single actor call (USD):
# APIFY_MAX_USD_PER_CALL=2

# ── Optional auth (lock down /api/* in production) ──
# Set both to require a key on every API call (no-op if unset):
# API_KEY=your-long-random-key          # server
# VITE_API_KEY=your-long-random-key     # client (same value)

# ─── Compliant API stubs (fill when you have access) ────
# NAUKRI_RESDEX_API_KEY=
# LINKEDIN_TALENT_TOKEN=

# ── Email sending (SMTP) ──────────────────────────────────
# SMTP_HOST UNSET → "test" mode: a free Ethereal inbox is used; emails are NOT
#   delivered to real people, each send returns a preview URL.
# SMTP_HOST SET   → "live" mode: emails are delivered for real via your SMTP.
# To go live, fill a provider block below, set EMAIL_FROM, and restart.
#
# SMTP_HOST     — SMTP hostname (setting this switches test → live)
# SMTP_PORT     — 587 STARTTLS (default) · 465 implicit TLS · 25 plain
# SMTP_SECURE   — "true" only for port 465; "false" for 587/25
# SMTP_USER     — SMTP username (often your email or an API key id)
# SMTP_PASS     — SMTP password / app-password / API key
# EMAIL_FROM    — From address recipients see (must be allowed by your provider)
# EMAIL_FROM_NAME — display name shown before the address
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=sourcing@yourdomain.com
# EMAIL_FROM_NAME=InCruiter Sourcing
#
# Provider quick-setup (uncomment ONE block, fill it in):
# Gmail/Workspace (use a 16-char App Password from myaccount.google.com/apppasswords):
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
#   SMTP_USER=you@yourdomain.com  SMTP_PASS=your-16-char-app-password
# SendGrid:  SMTP_HOST=smtp.sendgrid.net  SMTP_USER=apikey  SMTP_PASS=SG.xxxx
# Brevo:     SMTP_HOST=smtp-relay.brevo.com  SMTP_USER=login  SMTP_PASS=smtp-key
# Mailgun:   SMTP_HOST=smtp.mailgun.org  SMTP_USER=postmaster@mg.yourdomain.com
# Amazon SES:SMTP_HOST=email-smtp.<region>.amazonaws.com  (SES SMTP credentials)
# Mailtrap (QA, never delivers): SMTP_HOST=sandbox.smtp.mailtrap.io

# ── AI semantic JD matching (Groq only — fast & cheap) ────
# Without GROQ_API_KEY, JD matching falls back to keyword scoring.
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Security (REQUIRED for production) ────
# AUTH_SECRET signs login JWTs. MUST be a long random string in production — a
# known/default value lets anyone forge a login token. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# In production (NODE_ENV=production) the server refuses to start without it.
# AUTH_SECRET=
# CORS_ORIGIN — comma-separated allowed origins for the API in production
# (e.g. https://app.incruiter.com). Leave unset to allow any origin (dev only).
# CORS_ORIGIN=
